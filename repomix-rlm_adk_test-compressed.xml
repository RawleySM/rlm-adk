    all_results.append(obj)\n        except json.JSONDecodeError:\n            all_results.append({\"id\": r[\"id\"], \"error\": \"parse_failed\"})\n\nprint(f\"Total classified: {len(all_results)}\")\nfor res in all_results:\n    print(f\"  {res.get('id', '?')} -> {res.get('category', 'ERROR')}\")"
                    }
