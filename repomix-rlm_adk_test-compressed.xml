):\n            cleaned = cleaned.split(\"\\n\", 1)[-1].rsplit(\"```\", 1)[0].strip()\n        obj = json.loads(cleaned)\n        decision = TriageDecision.model_validate(obj)\n        if decision.matched_entity_id and decision.matched_entity_id not in symbol_table:\n            raise ValueError(f\"Hallucinated entity ID: {decision.matched_entity_id}\")\n        decisions.append(decision)\n    except Exception as exc:\n        errors.append({\"record_id\": r[\"id\"], \"error\": str(exc)})\n\nprint(f\"Decisions: {len(decisions)}, Errors: {len(errors)}\")\nfor d in decisions:\n    print(f\"  {d.record_id} -> {d.disposition.value} (conf={d.confidence})\")"
