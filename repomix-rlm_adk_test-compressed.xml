                      "code": "import json\nimport hashlib\nimport time\nfrom dataclasses import dataclass, field\nfrom typing import Any, Generic, TypeVar\n\nT = TypeVar(\"T\")\n\n@dataclass\nclass PhaseResult:\n    phase_name: str\n    items: list\n    errors: list = field(default_factory=list)\n    metadata: dict = field(default_factory=dict)\n\n@dataclass\nclass AdaptiveGate:\n    high_confidence_threshold: float = 0.85\n    low_confidence_threshold: float = 0.50\n    _recent_confidences: list = field(default_factory=list)\n    _window: int = 50\n\n    def record_confidence(self, conf):\n        self._recent_confidences.append(conf)\n        if len(self._recent_confidences) > self._window:\n            self._recent_confidences = self._recent_confidences[-self._window:]\n\n    @property\n    def rolling_mean(self):\n        if not self._recent_confidences:\n            return 0.5\n        return sum(self._recent_confidences) / len(self._recent_confidences)\n\n    def telemetry(self):\n        mean = self.rolling_mean\n        if mean >= self.high_confidence_threshold:\n            batch = 50\n        elif mean <= self.low_confidence_threshold:\n            batch = 5\n        else:\n            ratio = (mean - self.low_confidence_threshold) / (self.high_confidence_threshold - self.low_confidence_threshold)\n            batch = int(5 + ratio * 45)\n        return {\n            \"rolling_mean_confidence\": round(mean, 4),\n            \"sample_size\": len(self._recent_confidences),\n            \"recommended_batch_size\": batch,\n            \"recommended_max_retries\": 3 if mean < self.low_confidence_threshold else 1,\n        }\n\nclass DeduplicationRing:\n    def __init__(self):\n        self._hashes = set()\n    def __len__(self):\n        return len(self._hashes)\n    def mark_n(self, n):\n        for i in range(n):\n            self._hashes.add(hashlib.sha256(str(i).encode()).hexdigest())\n\ndef battlefield_report(phase_name, results, dedup_ring, adaptive_gate, wall_clock_s, unresolved_anomalies=None):\n    lines = [\"\", \"=\" * 78, f\"  BATTLEFIELD REPORT - Phase: {phase_name}\",\n             f\"  Wall clock: {wall_clock_s:.2f}s\", \"=\" * 78, \"\",\n             \"-- DISPOSITION DISTRIBUTION --\"]\n    total_items, total_errors = 0, 0\n    for disp, pr in sorted(results.items()):\n        n, e = len(pr.items), len(pr.errors)\n        total_items += n\n        total_errors += e\n        lines.append(f\"  {disp:.<30} {n:>5} items, {e:>3} errors\")\n    lines.extend([\"\", f\"  TOTAL PROCESSED: {total_items}\", f\"  TOTAL ERRORS: {total_errors}\",\n                   f\"  DEDUP RING SIZE: {len(dedup_ring)}\", \"\", \"-- ADAPTIVE GATE STATE --\"])\n    for k, v in adaptive_gate.telemetry().items():\n        lines.append(f\"  {k}: {v}\")\n    if unresolved_anomalies:\n        lines.extend([\"\", f\"-- UNRESOLVED ANOMALIES ({len(unresolved_anomalies)}) --\"])\n        for a in unresolved_anomalies[:5]:\n            lines.append(f\"  * [{a.get('record_id', '?')}] {a.get('error', '')[:80]}\")\n    lines.extend([\"\", \"-- NEXT ACTION REQUIRED --\"])\n    if total_errors > 0:\n        lines.append(\"  -> RECOMMEND: Inspect error payloads.\")\n    if unresolved_anomalies:\n        lines.append(\"  -> RECOMMEND: Triage anomalies.\")\n    if adaptive_gate.rolling_mean < adaptive_gate.low_confidence_threshold:\n        lines.append(\"  -> WARNING: Confidence below threshold.\")\n    if total_errors == 0 and not unresolved_anomalies:\n        lines.append(\"  -> ALL CLEAR: Proceed to commit/export.\")\n    lines.extend([\"\", \"=\" * 78])\n    return \"\\n\".join(lines)\n\n# --- Report 1: Healthy pipeline ---\nresults1 = {\n    \"exact_match\": PhaseResult(\"exact\", items=[{\"id\": i} for i in range(50)]),\n    \"fuzzy_match\": PhaseResult(\"fuzzy\", items=[{\"id\": i} for i in range(15)], errors=[{\"id\": \"E1\"}]),\n    \"anomaly\": PhaseResult(\"anomaly\", items=[{\"id\": i} for i in range(3)])\n}\ndedup = DeduplicationRing()\ndedup.mark_n(68)\ngate = AdaptiveGate()\nfor _ in range(20):\n    gate.record_confidence(0.88)\n\nreport1 = battlefield_report(\"HEALTHY_PIPELINE\", results1, dedup, gate, 12.5)\nprint(report1)\nhas_all_clear = \"ALL CLEAR\" not in report1  # has 1 error so not all clear\nhas_inspect = \"Inspect error\" in report1\nprint(f\"\\nReport 1 checks: has_inspect={has_inspect}, no_all_clear={has_all_clear}\")"
                    }
