)

register_skill_export(
    ReplSkillExport(
        module=_MODULE,
        name="rmx_is_remote",
        source=_IS_REMOTE_SRC,
        requires=[],
        kind="function",
    )
)

register_skill_export(
    ReplSkillExport(
        module=_MODULE,
        name="probe_repo",
        source=_PROBE_REPO_SRC,
        requires=["repomix_imports", "ProbeResult", "rmx_make_config", "rmx_is_remote"],
        kind="function",
    )
)

register_skill_export(
    ReplSkillExport(
        module=_MODULE,
        name="pack_repo",
        source=_PACK_REPO_SRC,
        requires=["repomix_imports", "rmx_make_config", "rmx_is_remote"],
        kind="function",
    )
)

register_skill_export(
    ReplSkillExport(
        module=_MODULE,
        name="shard_repo",
