_PARSE_CHUNK_ASSESSMENT_SRC = """\
def parse_chunk_assessment(response_text, chunk_id):
    text = str(response_text or "")
    status = "ABSENT"
    relevance_score = 0.0
    summary = ""
    for line in text.split("\\n"):
