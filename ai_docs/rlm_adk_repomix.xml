        upper = stripped.upper()
        if upper.startswith("CHUNK_STATUS:"):
            val = stripped.split(":", 1)[1].strip().upper()
            if val in ("PRESENT", "ABSENT"):
                status = val
        elif upper.startswith("RELEVANCE:"):
            val = stripped.split(":", 1)[1].strip()
            try:
