      "status": 200,
      "body": {
        "candidates": [
          {
            "content": {
              "role": "model",
              "parts": [
                {
                  "text": "Worker encountered authentication error (401 Unauthorized).\n\nFINAL(Worker auth error: 401 unauthorized)"
